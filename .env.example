# =============================================================================
# Шаблон переменных окружения
# Скопируйте этот файл в .env и заполните значениями:
#   cp .env.example .env
# Файл .env НЕ попадает в git — он содержит секреты.
# =============================================================================

# -----------------------------------------------------------------------------
# Google Service Account (обязательно)
# Используется для чтения содержимого Google Docs через API.
# Как получить:
#   1. Откройте Google Cloud Console → IAM & Admin → Service Accounts
#   2. Создайте сервисный аккаунт и скачайте JSON-ключ
#   3. Вставьте содержимое JSON-файла в одну строку (без переносов)
#   4. Не забудьте выдать аккаунту доступ к нужным документам в Google Docs
# -----------------------------------------------------------------------------
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# -----------------------------------------------------------------------------
# OpenRouter API Key (обязательно)
# Используется для AI-чата (обращения к языковым моделям).
# Получить ключ: https://openrouter.ai/keys
# -----------------------------------------------------------------------------
OPENROUTER_KEY=sk-or-v1-...

# -----------------------------------------------------------------------------
# JWT Secret (рекомендуется)
# Произвольная длинная случайная строка для подписи токенов авторизации.
# Если не задана, используется небезопасное значение по умолчанию.
# Сгенерировать: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# -----------------------------------------------------------------------------
JWT_SECRET=замените-на-случайную-строку-минимум-32-символа

# -----------------------------------------------------------------------------
# Admin PIN (необязательно, по умолчанию: 1234)
# PIN-код для входа в панель управления документами.
# -----------------------------------------------------------------------------
ADMIN_PIN=1234

# -----------------------------------------------------------------------------
# Порт сервера (необязательно, по умолчанию: 3001)
# -----------------------------------------------------------------------------
PORT=3001
